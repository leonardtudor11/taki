# Taki — environment template. Copy to .env and fill. NEVER commit .env.

# --- Bright Data (required: data layer) ---
# Get from BD dashboard after creating zones. One token works across zones.
BRIGHTDATA_API_KEY=
BRIGHTDATA_SERP_ZONE=
BRIGHTDATA_UNLOCKER_ZONE=
BRIGHTDATA_SCRAPER_ZONE=

# --- LLM reasoning (pick ONE path) ---
# Path A (PREFERRED, enterprise-safe): Vertex AI via Application Default Credentials.
# No JSON key needed. Run once on your Mac:
#   gcloud auth login
#   gcloud auth application-default login
#   gcloud auth application-default set-quota-project <PROJECT_ID>
# Then fill these — and leave GEMINI_API_KEY empty.
GCP_PROJECT_ID=
GCP_LOCATION=global

# Path B (fallback): Gemini AI Studio key (free tier, no GCP needed).
# Only set this if you are NOT using Vertex.
GEMINI_API_KEY=

# --- Second model for cross-checks (optional, reuse from diligence) ---
FEATHERLESS_API_KEY=

# --- spend safety ---
# Soft cap the pipeline enforces before each BD batch (USD).
TAKI_BD_SPEND_CAP=50
