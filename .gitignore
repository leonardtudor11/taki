# secrets
.env
*.key
*-sa.json

# python
.venv/
__pycache__/
*.pyc

# node / frontend
node_modules/
.next/
.vercel/

# data cache (keep dirs, ignore scraped payloads)
data/**/cache/
data/**/raw/

# failed BD targets — kept locally for forensics, never committed
# (stripe.com blocks Web Unlocker → empty bundle; see docs/RESUME.md)
data/stripe/

# event stream mirror — backend writes this beside brief.json on live runs;
# the dashboard's replay mode synthesizes its own timing from brief.json so
# committing this would only confuse (events for one target served alongside
# brief.json for a different target).
frontend/events.jsonl

# os
.DS_Store
